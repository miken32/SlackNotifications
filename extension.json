{
	"name": "Slack Notifications",
	"version": "2.5",
	"author": "Michael Newton<br/>Based on work by Aleksi Postari and contributors",
	"url": "https://github.com/miken32/slack_mediawiki",
	"description": "Sends Slack notifications for selected actions that have occurred in your MediaWiki sites.",
	"type": "other",
	"ConfigRegistry": {
		"SlackNotifications": "GlobalVarConfig::newInstance"
	},
	"AutoloadClasses": {
		"RadiusOne\\MediaWiki\\SlackNotifications": "SlackNotificationsCore.php"
	},
	"Hooks": {
		"PageSaveComplete"         : ["RadiusOne\\MediaWiki\\SlackNotifications::articleSaved"],
		"PageDeleteComplete"       : ["RadiusOne\\MediaWiki\\SlackNotifications::articleDeleted"],
		"PageMoveComplete"         : ["RadiusOne\\MediaWiki\\SlackNotifications::articleMoved"],
		"LocalUserCreated"         : ["RadiusOne\\MediaWiki\\SlackNotifications::newUserAccount"],
		"BlockIpComplete"          : ["RadiusOne\\MediaWiki\\SlackNotifications::userBlocked"],
		"UploadComplete"           : ["RadiusOne\\MediaWiki\\SlackNotifications::fileUploaded"],
		"ArticleProtectComplete"   : ["RadiusOne\\MediaWiki\\SlackNotifications::articleProtected"]
	},
	"config": {
		"SlackIncomingWebhookUrl": "",
		"SlackFromName": "",
		"SlackRoomName": "",
		"SlackEmoji": "",
		"SlackIncludePageUrls": true,
		"SlackIncludeUserUrls": true,
		"SlackIgnoreMinorEdits": false,
		"SlackExcludeGroup": "",
		"SlackExcludeNotificationsFrom": [],
		"SlackExcludedTitles": [],
		"SlackIncludedTitles": [],
		"SlackExcludedNamespaces": ["MediaWiki"],
		"SlackIncludedNamespaces": [],
		"SlackNotificationNewUser": true,
		"SlackNotificationBlockedUser": true,
		"SlackNotificationAddedArticle": true,
		"SlackNotificationRemovedArticle": true,
		"SlackNotificationMovedArticle": true,
		"SlackNotificationEditedArticle": true,
		"SlackNotificationFileUpload": true,
		"SlackNotificationProtectedArticle": true,
		"SlackIncludeDiffSize": true,
		"SlackShowNewUserEmail": true,
		"SlackShowNewUserFullName": true,
		"SlackShowNewUserIP": true,
		"SlackUsersAreWikiUsers": false
	},
	"manifest_version": 1
}
